{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/jpg-to-pdf", "destination": "/jpg-to-pdf.html" },
    { "source": "/png-to-pdf", "destination": "/png-to-pdf.html" },
    { "source": "/jpeg-to-pdf", "destination": "/jpeg-to-pdf.html" },
    { "source": "/image-to-pdf", "destination": "/image-to-pdf.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms-of-service", "destination": "/terms-of-service.html" },
    { "source": "/how-to-convert-jpg-to-pdf", "destination": "/how-to-convert-jpg-to-pdf.html" },
    { "source": "/sitemap", "destination": "/sitemap-page.html" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/index.php", "destination": "/", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/jpgtopdf", "destination": "/jpg-to-pdf", "permanent": true },
    { "source": "/jpg2pdf", "destination": "/jpg-to-pdf", "permanent": true },
    { "source": "/pngtopdf", "destination": "/png-to-pdf", "permanent": true },
    { "source": "/png2pdf", "destination": "/png-to-pdf", "permanent": true },
    { "source": "/jpegtopdf", "destination": "/jpeg-to-pdf", "permanent": true },
    { "source": "/imagetopdf", "destination": "/image-to-pdf", "permanent": true },
    { "source": "/faqs", "destination": "/faq", "permanent": true },
    { "source": "/privacy", "destination": "/privacy-policy", "permanent": true },
    { "source": "/terms", "destination": "/terms-of-service", "permanent": true },
    { "source": "/how-to", "destination": "/how-to-convert-jpg-to-pdf", "permanent": true },
    { "source": "/guide", "destination": "/how-to-convert-jpg-to-pdf", "permanent": true }
  ]
}
